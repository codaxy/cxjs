---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewLandingHeader from "../components/NewLandingHeader.astro";
import HoneycombBackground from "../components/HoneycombBackground.astro";
import Footer from "../components/Footer.astro";
import TrelloExample from "../examples/homepage/TrelloExample.tsx";
import InvoiceExample from "../examples/homepage/InvoiceExample.tsx";
import DashboardExample from "../examples/homepage/DashboardExample.tsx";
import InventoryExample from "../examples/homepage/InventoryExample.tsx";
---

<BaseLayout
  title="CxJS - The One-Stop Shop for Portals and Dashboards"
  description="A TypeScript UI framework with 50+ widgets, data tables, charts, routing, and state management designed for productivity and great developer experience."
>
  <style slot="head">
      /* Card hover effects */
      .feature-card {
        transition: all 0.3s ease;
      }
      .feature-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 40px -15px hsl(var(--primary) / 0.2);
      }
      .feature-card:hover .feature-icon {
        transform: scale(1.1) rotate(5deg);
      }
      .feature-icon {
        transition: transform 0.3s ease;
      }
  </style>
  <div class="min-h-screen bg-background transition-colors duration-300 nl-page">
    <NewLandingHeader />

    <!-- Hero (from new-landing) -->
    <section id="hero-section" class="relative pt-48 pb-64 lg:pt-96 lg:pb-112">
      <div
        class="absolute z-0 inset-0 overflow-hidden pointer-events-none dark:hidden"
      >
        <div
          class="absolute left-[calc(50%+100px)] -translate-x-1/2 top-[calc(50%-280px)] w-[300px] h-[300px] rounded-full opacity-30 blur-[80px]"
          style="background: radial-gradient(circle, #FFFFFF 0%, #80ECFF 40%, #A6A6FF 70%, transparent 100%);"
        >
        </div>
      </div>
      <div
        class="absolute z-0 inset-0 overflow-hidden pointer-events-none hidden dark:block"
      >
        <div
          class="absolute left-1/2 -translate-x-1/2 bottom-0 w-[800px] h-[500px] rounded-full opacity-40 blur-[120px]"
          style="background: radial-gradient(ellipse, #00BBFF 0%, #007BE0 40%, #6D00AD 70%, transparent 100%);"
        >
        </div>
      </div>

      <!-- Honeycomb background -->
      <div class="absolute z-[1] inset-0 overflow-hidden pointer-events-none">
        <img src="/honeycomb-light.png" fetchpriority="high" class="w-full h-full object-cover dark:hidden" alt="" />
        <img src="/honeycomb-dark.png" fetchpriority="high" class="w-full h-full object-cover hidden dark:block" alt="" />
      </div>
      <div class="absolute z-[2] inset-0 flex items-center justify-center overflow-hidden pointer-events-none">
        <HoneycombBackground />
      </div>

      <div class="relative z-10 mx-auto max-w-[900px] px-6 text-center">
        <!-- Badge -->
        <div
          class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-1.5 text-sm text-muted-foreground mb-8 transition-colors duration-300"
        >
          <span class="h-2 w-2 rounded-full bg-[#4ade80]"></span>
          Version 26 Now Available
        </div>

        <!-- Heading -->
        <h1
          class="text-4xl md:text-5xl lg:text-[64px] font-bold leading-[1.1] tracking-tight text-heading mb-6 transition-colors duration-300"
        >
          The One-Stop Shop for<br />
          Portals and Dashboards
        </h1>

        <!-- Description -->
        <p
          class="text-[16px] md:text-[18px] leading-relaxed text-muted-foreground max-w-[560px] mx-auto mb-10 transition-colors duration-300"
        >
          Born from a decade of development in finance, telecom and legal, CxJS
          bakes in the UI patterns teams keep rebuilding. Open source,
          battle-tested, and now TypeScript-first.
        </p>

        <!-- CTA Buttons -->
        <div class="flex items-center justify-center gap-3">
          <a
            href="/docs/intro/hello-world"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-[var(--cx-c-brand)] text-white text-[16px] font-medium hover:bg-[var(--cx-c-brand-dark)] transition-all duration-200 shadow-md hover:shadow-lg hover:-translate-y-0.5"
          >
            Get started
            <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor">
              <path
                d="M6.47 4.29a.75.75 0 0 1 1.06 0l3.75 3.75a.75.75 0 0 1 0 1.06l-3.75 3.75a.75.75 0 1 1-1.06-1.06L9.69 8.5H2.75a.75.75 0 0 1 0-1.5h6.94L6.47 5.35a.75.75 0 0 1 0-1.06z"
              ></path>
            </svg>
          </a>
          <a
            href="https://github.com/codaxy/cxjs"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-border bg-background text-foreground text-[16px] font-medium hover:bg-secondary/60 transition-all duration-200 hover:-translate-y-0.5"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </section>

    <!-- Features (from index) -->
    <section class="py-24 border-t border-border relative">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-heading mb-4">
            A Complete UI Framework in One Package
          </h2>
          <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
            Built as one cohesive system for data-driven web applications, with consistent patterns and a great developer experience.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <!-- Widgets -->
          <div class="feature-card p-6 rounded-xl border border-border bg-card/50 backdrop-blur-sm">
            <div class="feature-icon h-12 w-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
              <svg class="h-6 w-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7" rx="1"></rect>
                <rect x="14" y="3" width="7" height="7" rx="1"></rect>
                <rect x="3" y="14" width="7" height="7" rx="1"></rect>
                <rect x="14" y="14" width="7" height="7" rx="1"></rect>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-heading mb-3">Extensive Widget Library</h3>
            <ul class="text-sm text-muted-foreground space-y-1.5">
              <li class="flex items-start gap-2"><span class="text-primary">•</span>Forms with validation and lookups</li>
              <li class="flex items-start gap-2"><span class="text-primary">•</span>Tables with grouping, selection, and editing</li>
              <li class="flex items-start gap-2"><span class="text-primary">•</span>SVG charts for dashboards and reporting</li>
            </ul>
          </div>

          <!-- Navigation and App Shell -->
          <div class="feature-card p-6 rounded-xl border border-border bg-card/50 backdrop-blur-sm">
            <div class="feature-icon h-12 w-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
              <svg class="h-6 w-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"></rect>
                <path d="M3 9h18"></path>
                <path d="M9 21V9"></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-heading mb-3">Navigation and App Shell</h3>
            <ul class="text-sm text-muted-foreground space-y-1.5">
              <li class="flex items-start gap-2"><span class="text-primary">•</span>Client-side routing with URLs and history</li>
              <li class="flex items-start gap-2"><span class="text-primary">•</span>Layouts and overlays: menus, windows, tooltips</li>
              <li class="flex items-start gap-2"><span class="text-primary">•</span>Keyboard shortcuts and localization</li>
            </ul>
          </div>

          <!-- Ecosystem-Friendly -->
          <div class="feature-card p-6 rounded-xl border border-border bg-card/50 backdrop-blur-sm">
            <div class="feature-icon h-12 w-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
              <svg class="h-6 w-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path>
                <path d="M2 12h20"></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-heading mb-3">Ecosystem-Friendly</h3>
            <ul class="text-sm text-muted-foreground space-y-1.5">
              <li class="flex items-start gap-2"><span class="text-primary">•</span>Extends easily with React components</li>
              <li class="flex items-start gap-2"><span class="text-primary">•</span>Tailwind CSS support and theming</li>
              <li class="flex items-start gap-2"><span class="text-primary">•</span>Plays well with modern AI tooling</li>
            </ul>
          </div>

          <!-- Domain-Friendly -->
          <div class="feature-card p-6 rounded-xl border border-border bg-card/50 backdrop-blur-sm">
            <div class="feature-icon h-12 w-12 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
              <svg class="h-6 w-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3v18"></path>
                <rect x="4" y="8" width="6" height="12" rx="1"></rect>
                <rect x="14" y="4" width="6" height="16" rx="1"></rect>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-heading mb-3">Domain-Friendly</h3>
            <ul class="text-sm text-muted-foreground space-y-1.5">
              <li class="flex items-start gap-2"><span class="text-primary">•</span>Typed models as the source of truth</li>
              <li class="flex items-start gap-2"><span class="text-primary">•</span>Functional components for your domain</li>
              <li class="flex items-start gap-2"><span class="text-primary">•</span>Predictable data binding and formatting</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Code Preview (from index) -->
    <section class="py-24 border-t border-border bg-secondary/20 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-primary/5 to-transparent"></div>
      <div class="container mx-auto px-4 relative">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold text-heading mb-4">
              Predictable Developer Experience
            </h2>
            <p class="text-lg text-muted-foreground mb-6">
              Typed models, consistent binding, and layout primitives keep screens easy to build, easy to refactor, and easy to autocomplete.
            </p>
            <ul class="space-y-3 text-muted-foreground">
              <li class="flex items-center gap-3">
                <div class="h-2 w-2 rounded-full bg-primary"></div>
                JSX that stays clean as screens grow
              </li>
              <li class="flex items-center gap-3">
                <div class="h-2 w-2 rounded-full bg-primary"></div>
                Typed models for safe refactoring
              </li>
              <li class="flex items-center gap-3">
                <div class="h-2 w-2 rounded-full bg-primary"></div>
                Autocomplete for props, bindings, and values
              </li>
            </ul>
          </div>

          <div class="relative group min-w-0">
            <div class="absolute -inset-4 bg-gradient-to-r from-primary/20 via-cyan-500/20 to-purple-500/20 rounded-2xl blur-2xl opacity-50 group-hover:opacity-75 transition-opacity"></div>
            <pre class="relative overflow-x-auto p-6 rounded-xl border border-code-border bg-code-bg font-mono text-sm shadow-2xl">
<code class="text-gray-300"><span class="text-cyan-400">import</span><span class="text-gray-300"> &#123; TextField, LookupField &#125; </span><span class="text-cyan-400">from</span><span class="text-green-400"> 'cx/widgets'</span><span class="text-gray-300">;</span>
<span class="text-cyan-400">import</span><span class="text-gray-300"> &#123; createModel, LabelsTopLayout &#125; </span><span class="text-cyan-400">from</span><span class="text-green-400"> 'cx/ui'</span><span class="text-gray-300">;</span>

<span class="text-cyan-400">interface</span><span class="text-yellow-400"> UserModel</span><span class="text-gray-300"> &#123;</span>
<span class="text-gray-300">  firstName</span><span class="text-cyan-400">:</span><span class="text-green-400"> string</span><span class="text-gray-300">;</span>
<span class="text-gray-300">  lastName</span><span class="text-cyan-400">:</span><span class="text-green-400"> string</span><span class="text-gray-300">;</span>
<span class="text-gray-300">  email</span><span class="text-cyan-400">:</span><span class="text-green-400"> string</span><span class="text-gray-300">;</span>
<span class="text-gray-300">  countryId</span><span class="text-cyan-400">:</span><span class="text-green-400"> number</span><span class="text-gray-300">;</span>
<span class="text-gray-300">&#125;</span>

<span class="text-cyan-400">const</span><span class="text-gray-300"> m = </span><span class="text-yellow-400">createModel</span><span class="text-gray-300">&lt;</span><span class="text-yellow-400">UserModel</span><span class="text-gray-300">&gt;();</span>

<span class="text-cyan-400">export default</span><span class="text-gray-300"> (</span>
  <span class="text-purple-400">&lt;LabelsTopLayout</span> <span class="text-cyan-400">columns</span><span class="text-gray-300">=&#123;2&#125;</span><span class="text-purple-400">&gt;</span>
    <span class="text-yellow-400">&lt;TextField</span> <span class="text-cyan-400">value</span><span class="text-gray-300">=&#123;m.firstName&#125;</span> <span class="text-cyan-400">label</span><span class="text-gray-300">=</span><span class="text-green-400">"First Name"</span> <span class="text-yellow-400">/&gt;</span>
    <span class="text-yellow-400">&lt;TextField</span> <span class="text-cyan-400">value</span><span class="text-gray-300">=&#123;m.lastName&#125;</span> <span class="text-cyan-400">label</span><span class="text-gray-300">=</span><span class="text-green-400">"Last Name"</span> <span class="text-yellow-400">/&gt;</span>
    <span class="text-yellow-400">&lt;TextField</span> <span class="text-cyan-400">value</span><span class="text-gray-300">=&#123;m.email&#125;</span> <span class="text-cyan-400">label</span><span class="text-gray-300">=</span><span class="text-green-400">"Email"</span> <span class="text-yellow-400">/&gt;</span>
    <span class="text-yellow-400">&lt;LookupField</span> <span class="text-cyan-400">value</span><span class="text-gray-300">=&#123;m.countryId&#125;</span> <span class="text-cyan-400">label</span><span class="text-gray-300">=</span><span class="text-green-400">"Country"</span> <span class="text-cyan-400">options</span><span class="text-gray-300">=&#123;countries&#125;</span> <span class="text-yellow-400">/&gt;</span>
  <span class="text-purple-400">&lt;/LabelsTopLayout&gt;</span>
<span class="text-gray-300">);</span></code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- What You Can Build - Desktop Only (from index) -->
    <section class="hidden lg:block py-24 border-t border-border relative">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-heading mb-4">
            How It All Fits Together
          </h2>
          <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
            Interactive examples that combine models, widgets, and charts into real portal screens.
          </p>
        </div>

        <!-- Tabs -->
        <div class="flex justify-center gap-2 mb-8" id="example-tabs">
          <button class="example-tab px-6 py-2 rounded-lg font-medium transition-all bg-primary text-primary-foreground" data-tab="dashboard">Dashboard</button>
          <button class="example-tab px-6 py-2 rounded-lg font-medium transition-all bg-secondary text-secondary-foreground hover:bg-secondary/80" data-tab="trello">Trello Clone</button>
          <button class="example-tab px-6 py-2 rounded-lg font-medium transition-all bg-secondary text-secondary-foreground hover:bg-secondary/80" data-tab="invoice">Invoice Editor</button>
          <button class="example-tab px-6 py-2 rounded-lg font-medium transition-all bg-secondary text-secondary-foreground hover:bg-secondary/80" data-tab="inventory">Inventory</button>
        </div>

        <!-- Example Panels -->
        <div class="relative rounded-xl border border-border bg-card overflow-hidden" style="min-height: 500px;">
          <div class="example-panel" id="panel-dashboard">
            <DashboardExample client:load />
          </div>
          <div class="example-panel hidden" id="panel-trello">
            <TrelloExample client:visible />
          </div>
          <div class="example-panel hidden" id="panel-invoice">
            <InvoiceExample client:visible />
          </div>
          <div class="example-panel hidden" id="panel-inventory">
            <InventoryExample client:visible />
          </div>
        </div>
      </div>
    </section>

    <!-- CTA (from index) -->
    <section class="py-24 border-t border-border relative overflow-hidden">
      <div class="absolute inset-0 opacity-50" style="background-image: linear-gradient(to right, hsl(var(--border)) 1px, transparent 1px), linear-gradient(to bottom, hsl(var(--border)) 1px, transparent 1px); background-size: 60px 60px;"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-primary/10 rounded-full blur-3xl"></div>

      <div class="container mx-auto px-4 text-center relative">
        <h2 class="text-3xl md:text-4xl font-bold text-heading mb-4">
          Your Next Portal Starts Here
        </h2>
        <p class="text-lg text-muted-foreground max-w-xl mx-auto mb-8">
          Explore the docs, try the examples, and start building today.
        </p>
        <a
          href="/docs/intro/hello-world"
          class="group inline-flex items-center gap-2 px-8 py-4 rounded-lg bg-primary text-primary-foreground font-semibold hover:bg-primary/90 transition-all shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/30 hover:-translate-y-1"
        >
          Get Started
          <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </section>

    <Footer />
  </div>

  <script is:inline>
    function initNewLanding2() {
      // Example tabs
      const tabs = document.querySelectorAll('.example-tab');
      const panels = document.querySelectorAll('.example-panel');

      tabs.forEach(tab => {
        tab.onclick = () => {
          const targetTab = tab.dataset.tab;
          tabs.forEach(t => {
            if (t.dataset.tab === targetTab) {
              t.classList.remove('bg-secondary', 'text-secondary-foreground', 'hover:bg-secondary/80');
              t.classList.add('bg-primary', 'text-primary-foreground');
            } else {
              t.classList.remove('bg-primary', 'text-primary-foreground');
              t.classList.add('bg-secondary', 'text-secondary-foreground', 'hover:bg-secondary/80');
            }
          });
          panels.forEach(panel => {
            if (panel.id === `panel-${targetTab}`) {
              panel.classList.remove('hidden');
            } else {
              panel.classList.add('hidden');
            }
          });
        };
      });

      // Feature card animations
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

      document.querySelectorAll('.feature-card').forEach(card => {
        card.style.opacity = '0';
        card.style.transform = 'translateY(30px)';
        card.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
        observer.observe(card);
      });
    }

    document.addEventListener('astro:page-load', initNewLanding2);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initNewLanding2);
    } else {
      initNewLanding2();
    }
  </script>

  <style is:global>
    .dark .nl-page {
      --background: 218 36% 9%;
    }
  </style>
</BaseLayout>
