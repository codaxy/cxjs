  <script is:inline>
    (function () {
      function initNewLanding() {
        // Tabs
        var tabs = document.querySelectorAll(".nl-example-tab");
        var panels = document.querySelectorAll('[id^="nl-panel-"]');

        tabs.forEach(function (tab) {
          tab.onclick = function () {
            var target = tab.dataset.tab;

            tabs.forEach(function (t) {
              if (t.dataset.tab === target) {
                t.classList.remove("text-muted-foreground");
                t.classList.add("text-foreground", "bg-secondary/40");
                t.setAttribute("aria-selected", "true");
              } else {
                t.classList.remove("text-foreground", "bg-secondary/40");
                t.classList.add("text-muted-foreground");
                t.setAttribute("aria-selected", "false");
              }
            });

            panels.forEach(function (panel) {
              if (panel.id === "nl-panel-" + target) {
                panel.classList.remove("hidden");
              } else {
                panel.classList.add("hidden");
              }
            });
          };
        });

        // Copy code button
        var copyBtn = document.getElementById("nl-copy-code-btn");
        if (copyBtn) {
          copyBtn.onclick = function () {
            var codeEl = document.getElementById("nl-code-sample");
            if (!codeEl) return;
            var text = codeEl.textContent.replace(/^\s*\d+\s*/gm, "").trim();
            navigator.clipboard.writeText(text).then(function () {
              var copyIcon = copyBtn.querySelector(".copy-icon");
              var checkIcon = copyBtn.querySelector(".check-icon");
              if (copyIcon) copyIcon.classList.add("hidden");
              if (checkIcon) checkIcon.classList.remove("hidden");
              setTimeout(function () {
                if (copyIcon) copyIcon.classList.remove("hidden");
                if (checkIcon) checkIcon.classList.add("hidden");
              }, 2000);
            });
          };
        }

        // Copyright year
        var yearEl = document.getElementById("nl-copyright-year");
        if (yearEl) yearEl.textContent = new Date().getFullYear();
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initNewLanding);
      } else {
        initNewLanding();
      }
      document.addEventListener("astro:page-load", initNewLanding);
    })();
  </script>

