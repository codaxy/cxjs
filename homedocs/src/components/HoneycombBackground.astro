      { x1: 1319.9, y1: 786.75, x2: 1459.89, y2: 1029.0 },
    ];
    var GLOW_RADIUS = 150;

    function initHoneycomb() {
      var svg = document.getElementById("honeycomb-svg");
      if (!svg) return;
      var edgeEls = svg.querySelectorAll(".hc-edge");
      if (!edgeEls.length) return;
      var ns = "http://www.w3.org/2000/svg";
      var defs = svg.querySelector("defs");

      var grads = [];
      for (var i = 0; i < EDGES.length; i++) {
        var e = EDGES[i];
        var grad = document.createElementNS(ns, "linearGradient");
        grad.id = "hc-glow-" + i;
        grad.setAttribute("gradientUnits", "userSpaceOnUse");
        grad.setAttribute("x1", e.x1);
        grad.setAttribute("y1", e.y1);
        grad.setAttribute("x2", e.x2);
        grad.setAttribute("y2", e.y2);
        for (var s = 0; s < 5; s++) {
          var stop = document.createElementNS(ns, "stop");
          stop.setAttribute("offset", "0");
          stop.setAttribute("stop-color", "rgba(81,211,255,0)");
          grad.appendChild(stop);
        }
        defs.appendChild(grad);
        grads.push(grad);
        edgeEls[i].setAttribute("stroke", "url(#hc-glow-" + i + ")");
      }

      var glow = new Float32Array(EDGES.length);
      var glowT = new Float32Array(EDGES.length);
      for (var i = 0; i < EDGES.length; i++) glowT[i] = 0.5;
      var mouseX = -9999, mouseY = -9999;
      var hasMouseOver = false;
      var raf = 0;
      var SPREAD = 0.85;

      function onMove(e) {
        var rect = svg.getBoundingClientRect();
        mouseX = ((e.clientX - rect.left) / rect.width) * 1520;
        mouseY = ((e.clientY - rect.top) / rect.height) * 1089;
        hasMouseOver = true;
      }

      function onLeave() {
        hasMouseOver = false;
      }

      function projectOnSegment(px, py, x1, y1, x2, y2) {
        var dx = x2 - x1, dy = y2 - y1;
        var lenSq = dx * dx + dy * dy;
        if (lenSq === 0) return { dist: Math.sqrt((px - x1) * (px - x1) + (py - y1) * (py - y1)), t: 0 };
        var t = ((px - x1) * dx + (py - y1) * dy) / lenSq;
        t = Math.max(0, Math.min(1, t));
        var cx = x1 + t * dx, cy = y1 + t * dy;
        return { dist: Math.sqrt((px - cx) * (px - cx) + (py - cy) * (py - cy)), t: t };
      }

      function tick() {
        var dists = [];
        var projs = [];
        for (var i = 0; i < EDGES.length; i++) {
          var dist = Infinity, t = 0.5;
          if (hasMouseOver) {
            var e = EDGES[i];
            var p = projectOnSegment(mouseX, mouseY, e.x1, e.y1, e.x2, e.y2);
            dist = p.dist;
            t = p.t;
          }
          dists.push({ idx: i, dist: dist });
          projs.push(t);
        }

        for (var i = 0; i < EDGES.length; i++) {
          var target = 0;
          var targetT = glowT[i];
          var dist = dists[i].dist;
          if (dist < GLOW_RADIUS) {
            var f = 1 - dist / GLOW_RADIUS;
            target = f * f;
            targetT = projs[i];
          }
          glow[i] += (target - glow[i]) * 0.18;
          glowT[i] += (targetT - glowT[i]) * 0.25;
          if (glow[i] < 0.005 && target === 0) glow[i] = 0;

          var grad = grads[i];
          var stops = grad.children;
          if (glow[i] > 0.005) {
            var alpha = glow[i];
            var ct = glowT[i];
            var s0 = Math.max(0, ct - SPREAD);
            var s1 = Math.max(0, ct - SPREAD * 0.3);
            var s3 = Math.min(1, ct + SPREAD * 0.3);
            var s4 = Math.min(1, ct + SPREAD);

            stops[0].setAttribute("offset", s0.toFixed(4));
            stops[0].setAttribute("stop-color", "rgba(81,211,255,0)");
            stops[1].setAttribute("offset", s1.toFixed(4));
            stops[1].setAttribute("stop-color", "rgba(81,211,255," + (alpha * 0.4).toFixed(3) + ")");
            stops[2].setAttribute("offset", ct.toFixed(4));
            stops[2].setAttribute("stop-color", "rgba(81,211,255," + alpha.toFixed(3) + ")");
            stops[3].setAttribute("offset", s3.toFixed(4));
            stops[3].setAttribute("stop-color", "rgba(81,211,255," + (alpha * 0.4).toFixed(3) + ")");
            stops[4].setAttribute("offset", s4.toFixed(4));
            stops[4].setAttribute("stop-color", "rgba(81,211,255,0)");
          } else {
            for (var s = 0; s < 5; s++) {
              stops[s].setAttribute("stop-color", "rgba(81,211,255,0)");
            }
          }
        }
        raf = requestAnimationFrame(tick);
      }

      // Listen on the parent section so hover works over text too
      var section = svg.closest("section") || svg.parentElement;
      section.style.cursor = "default";
      section.addEventListener("mousemove", onMove);
      section.addEventListener("mouseleave", onLeave);
      raf = requestAnimationFrame(tick);
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initHoneycomb);
    } else {
      initHoneycomb();
    }
    document.addEventListener("astro:page-load", initHoneycomb);
